{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "gfx-vcpkg-cache",
  "$version-comment": "The version is imaginary, it is used to invalidate cache key in CI workflow for triplet_abi changes.",
  "version": "0.0.4",
  "dependencies": [
    {
      "name": "sdl2",
      "$required features" : "x11,wayland is enabled by default, Vulkan need enable",
      "features": [ "vulkan" ]
    },
    {
      "name": "glslang",
      "features": [ "tools"]
    },
    "zlib",
    "glm",
    "vulkan",
    "vulkan-validationlayers",
    "shader-slang",
    {
      "name": "usd",
      "features": [ "imaging", "materialx", "openimageio", "vulkan" ]
    }
  ],
  "overrides": [
    {
      "name": "usd",
      "version": "26.03"
    },
    {
      "name": "shader-slang",
      "version": "2026.7.1"
    }
  ],
  "builtin-baseline": "8cef5dcb6d18ec61b37251b509972c1fdf6fc63e"
}
